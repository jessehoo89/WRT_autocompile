# NSS (non-wireless core driver)
CONFIG_PACKAGE_sqm-scripts-nss=y
CONFIG_PACKAGE_kmod-qca-mcs=y
CONFIG_KERNEL_SKB_RECYCLER=y
CONFIG_KERNEL_SKB_RECYCLER_MULTI_CPU=y

# NSS kernel drive
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=y
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y

# ==========================================
# 全量禁用无线设置 (适用于高通NSS设备)
# 仅由 nowifi 设备通过 build.sh 自动加载
# ==========================================

# 1. 内核级无线子系统开关
CONFIG_WLAN=n
CONFIG_CFG80211=n
CONFIG_MAC80211=n
CONFIG_KERNEL_PREEMPT_RCU=n

# 2. NSS无线卸载与mesh功能
CONFIG_ATH11K_NSS_SUPPORT=y
CONFIG_ATH11K_NSS_MESH_SUPPORT=n
CONFIG_NSS_DRV_WIFI_MESH_ENABLE=n
CONFIG_NSS_DRV_WIFIOFFLOAD_ENABLE=n
CONFIG_PACKAGE_MAC80211_MESH=y

# 3.kmod相关
CONFIG_PACKAGE_kmod-crypto-aead=n
CONFIG_PACKAGE_kmod-crypto-ccm=n
CONFIG_PACKAGE_kmod-crypto-cmac=n
CONFIG_PACKAGE_kmod-crypto-ctr=n
CONFIG_PACKAGE_kmod-crypto-gcm=n
CONFIG_PACKAGE_kmod-crypto-gf128=n
CONFIG_PACKAGE_kmod-crypto-ghash=n
CONFIG_PACKAGE_kmod-crypto-hmac=n
CONFIG_PACKAGE_kmod-crypto-manager=n
CONFIG_PACKAGE_kmod-crypto-michael-mic=n
CONFIG_PACKAGE_kmod-crypto-null=n
CONFIG_PACKAGE_kmod-crypto-rng=n
CONFIG_PACKAGE_kmod-crypto-seqiv=n
CONFIG_PACKAGE_kmod-crypto-sha3=n
CONFIG_PACKAGE_kmod-crypto-sha512=n
CONFIG_PACKAGE_kmod-hwmon-core=n
CONFIG_PACKAGE_kmod-i2c-core=n
CONFIG_PACKAGE_kmod-mhi-bus=n
CONFIG_PACKAGE_kmod-qrtr-mhi=n
CONFIG_PACKAGE_kmod-qrtr-smd=n

# 4.内核无线驱动
CONFIG_PACKAGE_kmod-rt2800-usb=n
CONFIG_PACKAGE_kmod-rtl8xxxu=n
CONFIG_PACKAGE_kmod-rtl8188eu=n
CONFIG_PACKAGE_kmod-rtl8189es=n
CONFIG_PACKAGE_kmod-rtl8192c-common=n
CONFIG_PACKAGE_kmod-rtl8192ce=n
CONFIG_PACKAGE_kmod-rtl8192cu=n
CONFIG_PACKAGE_kmod-rtl8192d-common=n
CONFIG_PACKAGE_kmod-rtl8192de=n
CONFIG_PACKAGE_kmod-rtl8192du=n
CONFIG_PACKAGE_kmod-rtl8192se=n
CONFIG_PACKAGE_kmod-rtl8723-common=n
CONFIG_PACKAGE_kmod-rtl8723be=n
CONFIG_PACKAGE_kmod-rtl8723bs=n
CONFIG_PACKAGE_kmod-rtl8812au-ct=n
CONFIG_PACKAGE_kmod-rtl8821ae=n
CONFIG_PACKAGE_kmod-rtl8xxxu=n
CONFIG_PACKAGE_kmod-rtlwifi-btcoexist=n
CONFIG_PACKAGE_kmod-rtlwifi-pci=n
CONFIG_PACKAGE_kmod-rtlwifi-usb=n
CONFIG_PACKAGE_kmod-rtlwifi=n
CONFIG_PACKAGE_kmod-ath10k-sdio=n
CONFIG_PACKAGE_kmod-ath6kl-sdio=n
CONFIG_PACKAGE_kmod-aic8800-btusb=n
CONFIG_PACKAGE_kmod-aic8800-pcie=n
CONFIG_PACKAGE_kmod-aic8800-sdio=n
CONFIG_PACKAGE_kmod-aic8800-usb=n

# 5. 无线内核驱动模块 (高通全系)
CONFIG_PACKAGE_kmod-ath=n
CONFIG_PACKAGE_kmod-ath5k=n
CONFIG_PACKAGE_kmod-ath9k=n
CONFIG_PACKAGE_kmod-ath9k-common=n
CONFIG_PACKAGE_kmod-ath10k=n
CONFIG_PACKAGE_kmod-ath10k-ct=n
CONFIG_PACKAGE_kmod-ath10k-smallbuffers=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_kmod-qca-ssdk=n
CONFIG_PACKAGE_kmod-qca-nss-drv-netlink=n

# 6. 无线固件 (高通NSS相关)
CONFIG_PACKAGE_ath10k-firmware-qca4019=n
CONFIG_PACKAGE_ath10k-firmware-qca988x=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq8074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n
CONFIG_PACKAGE_ipq-wifi-zn_m2=n


# 7. 用户态无线工具与服务
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_wireless-tools=n
CONFIG_PACKAGE_wpa-cli=n
CONFIG_PACKAGE_wpa-supplicant=n
CONFIG_PACKAGE_hostapd=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_wpad=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_wpad-mesh-openssl=n
CONFIG_PACKAGE_wpad-wolfssl=n
CONFIG_PACKAGE_apk-mbedtls=n
CONFIG_PACKAGE_apk-openssl=n

# 8. 无线脚本与配置
CONFIG_PACKAGE_wifi-scripts=n
CONFIG_PACKAGE_wireless-regdb=n
CONFIG_PACKAGE_rpcd-mod-iwinfo=n

# 9. ucode模块 (无线相关)
CONFIG_PACKAGE_ucode-mod-digest=n
CONFIG_PACKAGE_ucode-mod-nl80211=n
CONFIG_PACKAGE_ucode-mod-rtnl=n
CONFIG_PACKAGE_ucode-mod-uloop=n

# 10. LuCI无线界面
CONFIG_PACKAGE_luci-proto-wireless=n
CONFIG_PACKAGE_luci-app-wireless=n
CONFIG_PACKAGE_luci-app-wifi=n

# 11. 无线驱动
CONFIG_DRIVER_11AC_SUPPORT=n
CONFIG_DRIVER_11AX_SUPPORT=n

# 12.无线库
CONFIG_PACKAGE_libopenssl-conf=n
CONFIG_PACKAGE_libopenssl-legacy=n